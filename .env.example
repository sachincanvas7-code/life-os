# Life OS — Environment Variables
# Copy this file to .env and fill in your values

# Resend API key (get one free at resend.com)
RESEND_API_KEY=re_your_key_here

# Email to send the report to
TO_EMAIL=your@email.com

# Sending address (use onboarding@resend.dev if you haven't verified a domain)
FROM_EMAIL=onboarding@resend.dev

# Absolute path to your projects root directory
WORK_DIR=/path/to/your/projects

# Minimum days between sends (scheduler runs daily; this enforces the spacing)
REPORT_EVERY_DAYS=3
